# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb+srv://railmadad:REDACTED_MONGO_PASS@cluster0.wcsunfg.mongodb.net/?appName=Cluster0


# JWT Secret
JWT_SECRET=REDACTED_JWT_SECRET
JWT_EXPIRE=365d

# Admin Secret Key (required to create admin accounts)
ADMIN_SECRET_KEY=your_admin_secret_key
ADMIN_EMAIL=cjhimanshu49@gmail.com
ADMIN_PASSWORD=@1234567

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=Root
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Hugging Face AI API
HUGGINGFACE_API_KEY=hf_your_token_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ─── Redis (BullMQ AI queue) ──────────────────────────────────────────────────
# Without Redis the server still works — AI falls back to setImmediate (in-process async)
REDIS_URL=redis://localhost:6379

# ─── Scaling knobs ────────────────────────────────────────────────────────────
# Parallel AI jobs processed by the queue worker at once (default: 20)
AI_QUEUE_CONCURRENCY=20
# Worker processes to spawn in production (default: number of CPU cores)
# WEB_CONCURRENCY=4
