# Server Configuration
PORT=5001
NODE_ENV=development

# Database (MongoDB Atlas connection string)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0


# JWT Secret
JWT_SECRET=your_long_random_jwt_secret_here
JWT_EXPIRE=365d

# Admin Secret Key (required to create admin accounts)
ADMIN_SECRET_KEY=your_admin_secret_key_here
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_admin_password_here

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Hugging Face AI API
HUGGINGFACE_API_KEY=hf_your_token_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ─── Email — Resend (https://resend.com) ───────────────────────────────────────
# 1. Sign up free at https://resend.com — no credit card needed
# 2. Create an API key in the Resend dashboard
# 3. Paste it below — that's it, no SMTP host/port/password needed
RESEND_API_KEY=re_your_api_key_here
# From address — must be a domain you verify in Resend dashboard
# While testing you can use: onboarding@resend.dev (only sends to your own account email)
RESEND_FROM_EMAIL=RailMadad <noreply@yourdomain.com>

# ─── Scaling knobs ────────────────────────────────────────────────────────────
# Parallel AI jobs processed by the queue worker at once (default: 20)
AI_QUEUE_CONCURRENCY=20
# Worker processes to spawn in production (default: number of CPU cores)
# WEB_CONCURRENCY=4
