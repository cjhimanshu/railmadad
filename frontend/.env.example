# ─── Backend URL ──────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:5000/api

# ─── Firebase Web App config ──────────────────────────────────────────────────
# 1. Firebase Console → Project Settings → General → Your apps → Web app
# 2. Copy the firebaseConfig values below
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abc123...

# ─── FCM VAPID key (Web Push certificates) ────────────────────────────────────
# Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
# → Generate key pair, then copy the Key pair value here
VITE_FIREBASE_VAPID_KEY=BH...your-vapid-key...
